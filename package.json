{
  "name": "mcp-handson",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.30.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v",
    "dev:auth": "pnpm --filter local-auth-server dev",
    "dev:mcp:http": "pnpm --filter task-notes-mcp dev:http",
    "dev:mcp:stdio": "pnpm --filter task-notes-mcp dev:stdio"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
